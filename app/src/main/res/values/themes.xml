<resources xmlns:tools="http://schemas.android.com/tools">
    <!--
        Theme for a modern Jetpack Compose + Material 3 fullscreen image viewer.
        NoActionBar because Compose owns the UI. Black background is ideal for images.
    -->
    <style name="Theme.SimpleImageViewer" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Make the window background black so images look best during loading / letterboxing -->
        <item name="android:windowBackground">@android:color/black</item>

        <!-- Edge-to-edge + fullscreen friendly -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="o_mr1">shortEdges</item>

        <!-- Optional: make sure we draw behind the system bars until we hide them -->
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>
</resources>